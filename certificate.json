{
"name": "Certificate HTML",
"nodes": [
{
"parameters": {
"path": "certificate",
"httpMethod": "GET",
"responseMode": "lastNode"
},
"name": "Webhook",
"type": "n8n-nodes-base.webhook",
"typeVersion": 1,
"position": [200, 300]
},
{
"parameters": {
"values": {
"string": [
{
"name": "name",
"value": "={{$json.query.name || 'ไม่ระบุชื่อ'}}"
},
{
"name": "course",
"value": "={{$json.query.course || 'ไม่ระบุหลักสูตร'}}"
}
]
}
},
"name": "Set Data",
"type": "n8n-nodes-base.set",
"typeVersion": 2,
"position": [400, 300]
},
{
"parameters": {
"html": "<html><body style="text-align:center;font-family:sans-serif;padding:50px;"><h1 style="font-size:40px;">เกียรติบัตร</h1><p>ขอมอบให้แก่</p><h2 style="color:blue;">{{$json.name}}</h2><p>ได้ผ่านการอบรม</p><h3>{{$json.course}}</h3><br><br><p>ลงชื่อ................................</p></body></html>"
},
"name": "Generate HTML",
"type": "n8n-nodes-base.html",
"typeVersion": 1,
"position": [600, 300]
}
],
"connections": {
"Webhook": {
"main": [
[
{
"node": "Set Data",
"type": "main",
"index": 0
}
]
]
},
"Set Data": {
"main": [
[
{
"node": "Generate HTML",
"type": "main",
"index": 0
}
]
]
}
}
}
